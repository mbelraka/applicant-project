GROQ_API_KEY=gsk_your_secret_key_here
PORT=3000

# Comma-separated browser origins allowed to call this API (default: localhost:4200 for ng serve).
# Production: explicit https:// origins — NODE_ENV=production refuses CORS_ORIGIN=* at startup.
# CORS_ORIGIN=https://app.example.com

# Optional: terminate TLS inside Node instead of only at nginx/ingress.
# Uncomment both for HTTPS on PORT (pem paths readable by this process).
# TLS_CERT_PATH=/path/to/fullchain.pem
# TLS_KEY_PATH=/path/to/privkey.pem

# When TLS_CERT_PATH/TLS_KEY_PATH are set, HSTS is emitted by default; use this for local certs / testing.
# DISABLE_HSTS=1

# HSTS preload token (Harmful if misconfigured.) Only enable when committing to preload list submission.
# HSTS_PRELOAD=1

# Max POST /api/match requests per IP per window (see server-config MATCH_RATE_LIMIT, default 100).
# MATCH_RATE_LIMIT_MAX=200

# Set to 1 when running behind a reverse proxy so rate limits use X-Forwarded-For.
# TRUST_PROXY=1

# Force HSTS from this Node process when TLS terminates elsewhere (HTTPS end-to-end to client).
# With Node TLS, HSTS defaults on unless DISABLE_HSTS=1.
# ENABLE_HSTS=1
