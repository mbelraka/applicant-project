{
  "name": "@recruita/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,yml,yaml}\" --ignore-path ../.prettierignore",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,yml,yaml}\" --ignore-path ../.prettierignore",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "quality": "npm run format:check && npm run lint",
    "quality:fix": "npm run format && npm run lint:fix",
    "doctor": "angular-doctor --yes --fast --no-lint .",
    "doctor:full": "angular-doctor --yes --no-lint .",
    "doctor:lint": "angular-doctor --yes --fast --exit-code .",
    "security:audit": "ngx-security-audit scan -t high --no-color .",
    "letify": "letify analyze \"src/**/*.html\" -r list --open false",
    "test": "ng test",
    "test:ci": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessNoSandbox",
    "test:coverage": "ng test --code-coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "clean": "rimraf dist/"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@fontsource/manrope": "^5.2.8",
    "@mdi/font": "^7.4.47",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/entity": "^20.0.0",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "rxjs": "^7.8.1",
    "sass": "^1.70.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.11",
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/localize": "^21.2.13",
    "@eslint/config-array": "^0.23.5",
    "@eslint/object-schema": "^3.0.5",
    "@jsverse/letify": "^1.0.0",
    "@playwright/test": "^1.60.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.18.0",
    "@typescript-eslint/utils": "^8.59.4",
    "angular-doctor": "^1.3.0",
    "autoprefixer": "^10.5.0",
    "beasties": "^0.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "glob": "^13.0.6",
    "jasmine-core": "^6.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ngx-security-audit": "^2.0.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "webpack": "^5.96.1"
  }
}
