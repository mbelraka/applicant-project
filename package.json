{
  "name": "recruita",
  "version": "0.0.0",
  "private": true,
  "description": "Recruita monorepo — recruitment workspace (Angular frontend, backend services)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "npm run start -w @recruita/frontend",
    "start:server": "npm run start -w @recruita/backend",
    "start:all": "sh -c 'npm run start -w @recruita/frontend & npm run start -w @recruita/backend'",
    "build": "npm run build -w @recruita/frontend",
    "build:prod": "npm run build:prod -w @recruita/frontend",
    "watch": "npm run watch -w @recruita/frontend",
    "format": "npm run format -w @recruita/frontend",
    "format:check": "npm run format:check -w @recruita/frontend",
    "lint": "npm run lint -w @recruita/frontend",
    "lint:fix": "npm run lint:fix -w @recruita/frontend",
    "quality": "npm run quality -w @recruita/frontend",
    "quality:fix": "npm run quality:fix -w @recruita/frontend",
    "doctor": "npm run doctor -w @recruita/frontend",
    "doctor:full": "npm run doctor:full -w @recruita/frontend",
    "doctor:lint": "npm run doctor:lint -w @recruita/frontend",
    "security:audit": "npm run security:audit -w @recruita/frontend",
    "letify": "npm run letify -w @recruita/frontend",
    "precommit:checks": "npm run doctor -w @recruita/frontend && npm run security:audit -w @recruita/frontend && npm run letify -w @recruita/frontend && npm run build:prod -w @recruita/frontend && npm run test:ci -w @recruita/frontend && npm run test -w @recruita/backend",
    "validate": "npm run quality && npm run precommit:checks",
    "validate:ci": "npm run quality && npm run test:ci -w @recruita/frontend && npm run test -w @recruita/backend && npm run doctor:full -w @recruita/frontend && npm run security:audit -w @recruita/frontend && npm run letify -w @recruita/frontend && npm run build:prod -w @recruita/frontend",
    "test": "npm run test -w @recruita/frontend",
    "test:ci": "npm run test:ci -w @recruita/frontend",
    "test:server": "npm run test -w @recruita/backend",
    "test:coverage": "npm run test:coverage -w @recruita/frontend",
    "e2e": "npm run e2e -w @recruita/frontend",
    "e2e:ui": "npm run e2e:ui -w @recruita/frontend",
    "e2e:headed": "npm run e2e:headed -w @recruita/frontend",
    "e2e:install": "npm run e2e:install -w @recruita/frontend",
    "clean": "npm run clean -w @recruita/frontend",
    "lockfile:check": "npx -y npm@10.9.2 install --package-lock-only --ignore-scripts && git diff --exit-code package-lock.json",
    "prepare": "husky"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "@babel/helper-compilation-targets": {
      "lru-cache": "5.1.1"
    }
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,html}": [
      "bash -c 'cd frontend && eslint --fix --max-warnings=0 \"$@\"' _",
      "prettier --write"
    ],
    "frontend/e2e/**/*.{ts,html}": [
      "prettier --write"
    ],
    "frontend/playwright.config.ts": [
      "prettier --write"
    ],
    "frontend/**/*.{scss,css,json,yml,yaml}": [
      "prettier --write"
    ],
    "backend/**/*.{cjs,json}": [
      "prettier --write"
    ],
    "*.{scss,css,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
